# Anthropic API Key (paste from chief-final/.env.local)
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# Optional: post-session sync to chief-final dashboard
CHIEF_SYNC_URL=https://chiefracing.com/api/sim/sync-session
CHIEF_SYNC_TOKEN=

# Voice
VOICE_RATE=180
VOICE_VOLUME=1.0
VOICE_INDEX=0

# Coaching tuning
COACH_VERBOSITY=chatty             # quiet | normal | chatty
COACH_MIN_INTERVAL_SEC=6
COACH_MIN_DELTA_SEC=0.20
COACH_MAX_CALLS_PER_LAP=6
COACH_SECTOR_LOSS_THRESHOLD=0.10
SECTOR_COUNT=10

# Push-to-talk
PTT_ENABLED=true
PTT_HOTKEY=f8                      # hold to ask Chief a question

# Setup archive
SETUP_ARCHIVE_ENABLED=true
IRACING_SETUPS_PATH=               # blank = auto-detect (Documents\iRacing\setups)
SETUP_ARCHIVE_DIR=                 # blank = ./setups_archive

LOG_LEVEL=INFO

# Hardware (SimuCube + SimMagic) auto-archive
HARDWARE_ARCHIVE_ENABLED=true
HARDWARE_ARCHIVE_DIR=               # blank = ./hardware_archive
HARDWARE_WATCH_PATHS=               # optional ; separated extra dirs to watch
